{
  "openapi": "3.1.0",
  "info": {
    "title": "WalletNest API",
    "version": "1.0.0",
    "description": "Read-only Ethereum wallet data: native balance, ERC-20 tokens, NFTs, and recent transfers. All data is sourced from Alchemy and normalized into stable shapes.\n\nEvery request needs **two** credentials:\n\n1. `Authorization: Bearer wnk_...` — your WalletNest API key, which grants access.\n2. `X-Alchemy-Key: ...` — your own [Alchemy](https://dashboard.alchemy.com) key, which pays for the chain data.\n\nThis is bring-your-own-key: you are billed by Alchemy for your own usage, and WalletNest's quota is never spent on your behalf.\n\nThis API is server-to-server. Neither key may be embedded in a browser or mobile client.",
    "contact": {
      "name": "Adefoluke Adesewa",
      "url": "https://www.linkedin.com/in/adefoluke-adesewa"
    },
    "license": { "name": "MIT" }
  },
  "servers": [
    {
      "url": "https://wallet-nest-nine.vercel.app/api/v1",
      "description": "Production (replace with your Vercel domain)"
    },
    {
      "url": "http://localhost:3000/api/v1",
      "description": "Local development"
    }
  ],
  "security": [{ "bearerAuth": [], "alchemyKey": [] }],
  "tags": [
    { "name": "Wallets", "description": "Single-wallet lookups" },
    { "name": "Portfolio", "description": "Cross-wallet aggregation" }
  ],
  "paths": {
    "/wallets/{address}": {
      "get": {
        "tags": ["Wallets"],
        "operationId": "getWallet",
        "summary": "Get a wallet",
        "description": "Returns the native ETH balance, non-zero ERC-20 balances, up to 20 NFTs, and the 15 most recent transfers for a single address.",
        "parameters": [
          {
            "name": "address",
            "in": "path",
            "required": true,
            "description": "Ethereum address, `0x` followed by 40 hex characters.",
            "schema": {
              "type": "string",
              "pattern": "^0x[a-fA-F0-9]{40}$",
              "examples": ["0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Wallet data",
            "headers": {
              "X-Request-Id": { "$ref": "#/components/headers/XRequestId" },
              "X-API-Version": { "$ref": "#/components/headers/XApiVersion" }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Wallet" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "502": { "$ref": "#/components/responses/UpstreamError" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/portfolio": {
      "post": {
        "tags": ["Portfolio"],
        "operationId": "createPortfolio",
        "summary": "Aggregate several wallets",
        "description": "Fetches every address in parallel and returns per-wallet data alongside portfolio-wide totals.\n\nThis endpoint is partially fault-tolerant: if an individual address fails upstream, the response is still `200` and that wallet carries an `error` field. Totals only count wallets that loaded successfully. Check each wallet's `error` before trusting its numbers.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PortfolioRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Aggregated portfolio",
            "headers": {
              "X-Request-Id": { "$ref": "#/components/headers/XRequestId" },
              "X-API-Version": { "$ref": "#/components/headers/XApiVersion" }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Portfolio" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Your WalletNest API key — grants access to this API. Send as `Authorization: Bearer wnk_live_...`. The header `X-API-Key: wnk_live_...` is also accepted."
      },
      "alchemyKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Alchemy-Key",
        "description": "Your own Alchemy API key — pays for the chain data. Get one free at https://dashboard.alchemy.com; it must be enabled for Ethereum mainnet. Must match `^[A-Za-z0-9_-]{16,64}$`."
      }
    },
    "headers": {
      "XRequestId": {
        "description": "Unique id for this request. Include it when reporting a problem.",
        "schema": { "type": "string", "format": "uuid" }
      },
      "XApiVersion": {
        "description": "The API version that served the response.",
        "schema": { "type": "string", "examples": ["v1"] }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "The request was malformed — a bad address, an invalid body, or a missing/rejected `X-Alchemy-Key`. Never worth retrying unchanged.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" },
            "example": {
              "error": {
                "code": "invalid_address",
                "message": "'0xnope' is not a valid Ethereum address.",
                "requestId": "3f1c9c1e-4a2b-4d3e-9f00-9a1b2c3d4e5f"
              }
            }
          }
        }
      },
      "Unauthorized": {
        "description": "The API key was missing, malformed, or not recognized.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" },
            "example": {
              "error": {
                "code": "unauthorized",
                "message": "Missing API key. Send 'Authorization: Bearer <key>' or 'X-API-Key: <key>'.",
                "requestId": "3f1c9c1e-4a2b-4d3e-9f00-9a1b2c3d4e5f"
              }
            }
          }
        }
      },
      "UpstreamError": {
        "description": "The upstream chain data provider failed or timed out.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" },
            "example": {
              "error": {
                "code": "upstream_error",
                "message": "Could not reach the chain data provider. Try again shortly.",
                "requestId": "3f1c9c1e-4a2b-4d3e-9f00-9a1b2c3d4e5f"
              }
            }
          }
        }
      },
      "InternalError": {
        "description": "Something broke on our side.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "object",
            "required": ["code", "message", "requestId"],
            "properties": {
              "code": {
                "type": "string",
                "description": "Stable, machine-readable identifier. Branch on this, not on `message`.",
                "enum": [
                  "unauthorized",
                  "invalid_address",
                  "invalid_request",
                  "missing_alchemy_key",
                  "invalid_alchemy_key",
                  "not_found",
                  "upstream_error",
                  "internal_error",
                  "server_misconfigured"
                ]
              },
              "message": {
                "type": "string",
                "description": "Human-readable explanation. Wording may change; do not parse."
              },
              "requestId": { "type": "string", "format": "uuid" }
            }
          }
        }
      },
      "TokenBalance": {
        "type": "object",
        "required": ["contractAddress", "symbol", "name", "logo", "balance", "decimals"],
        "properties": {
          "contractAddress": { "type": "string", "examples": ["0xa0b86991c6218b36c1d19d4a2e9eb0ce3606eb48"] },
          "symbol": { "type": "string", "description": "`???` when the token exposes no symbol.", "examples": ["USDC"] },
          "name": { "type": "string", "description": "`Unknown Token` when metadata is unavailable.", "examples": ["USD Coin"] },
          "logo": { "type": ["string", "null"], "format": "uri" },
          "balance": {
            "type": "number",
            "description": "Already scaled by `decimals` — human readable. Large balances may lose precision in IEEE-754; treat as display values, not accounting values.",
            "examples": [1523.44]
          },
          "decimals": { "type": "integer", "examples": [6] }
        }
      },
      "NftItem": {
        "type": "object",
        "required": ["contractAddress", "tokenId", "title", "collectionName", "imageUrl"],
        "properties": {
          "contractAddress": { "type": "string" },
          "tokenId": { "type": "string", "description": "Stringified — token ids exceed the safe integer range." },
          "title": { "type": "string" },
          "collectionName": { "type": "string" },
          "imageUrl": { "type": ["string", "null"], "format": "uri" }
        }
      },
      "Transaction": {
        "type": "object",
        "required": ["hash", "from", "to", "value", "asset", "category", "blockNum", "direction"],
        "properties": {
          "hash": { "type": "string" },
          "from": { "type": "string" },
          "to": { "type": ["string", "null"], "description": "Null for contract creations." },
          "value": { "type": "number", "description": "Human-readable amount of `asset`." },
          "asset": { "type": "string", "examples": ["ETH"] },
          "category": { "type": "string", "enum": ["external", "erc20", "erc721", "erc1155"] },
          "blockNum": { "type": "string", "description": "Hex-encoded block number.", "examples": ["0x120a4b2"] },
          "direction": { "type": "string", "enum": ["in", "out"], "description": "Relative to the queried address." }
        }
      },
      "Wallet": {
        "type": "object",
        "required": ["address", "nativeBalance", "tokens", "nfts", "transactions"],
        "properties": {
          "address": { "type": "string" },
          "nativeBalance": { "type": "number", "description": "ETH balance, human readable." },
          "tokens": {
            "type": "array",
            "description": "Non-zero ERC-20 balances, descending by balance.",
            "items": { "$ref": "#/components/schemas/TokenBalance" }
          },
          "nfts": {
            "type": "array",
            "description": "Up to 20 owned NFTs. Not paginated in v1.",
            "items": { "$ref": "#/components/schemas/NftItem" }
          },
          "transactions": {
            "type": "array",
            "description": "The 15 most recent transfers in or out, newest first.",
            "items": { "$ref": "#/components/schemas/Transaction" }
          },
          "error": {
            "type": "string",
            "description": "Only present inside `POST /portfolio`, when this one wallet failed to load. Never present on `GET /wallets/{address}` — that endpoint returns a non-200 status instead."
          }
        }
      },
      "PortfolioRequest": {
        "type": "object",
        "required": ["addresses"],
        "properties": {
          "addresses": {
            "type": "array",
            "description": "Ethereum addresses to aggregate. Duplicates are collapsed case-insensitively.",
            "items": { "type": "string", "pattern": "^0x[a-fA-F0-9]{40}$" },
            "minItems": 1,
            "maxItems": 25,
            "examples": [["0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045"]]
          }
        }
      },
      "Portfolio": {
        "type": "object",
        "required": [
          "wallets",
          "totalNativeBalance",
          "totalTokenCount",
          "totalNftCount",
          "totalTransactionCount"
        ],
        "properties": {
          "wallets": { "type": "array", "items": { "$ref": "#/components/schemas/Wallet" } },
          "totalNativeBalance": { "type": "number", "description": "Sum of ETH across wallets that loaded successfully." },
          "totalTokenCount": { "type": "integer" },
          "totalNftCount": { "type": "integer", "description": "Counts returned NFTs (capped at 20 per wallet), not total owned." },
          "totalTransactionCount": { "type": "integer", "description": "Counts returned transfers (capped at 15 per wallet), not lifetime total." }
        }
      }
    }
  }
}
