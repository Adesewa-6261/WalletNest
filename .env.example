# Get a free key at https://dashboard.alchemy.com
# Create an app on Ethereum Mainnet, then copy the API key here.
#
# This key backs the DASHBOARD only. /api/v1 callers bring their own key via the
# X-Alchemy-Key header and pay for their own usage, so this quota is only spent
# by people browsing your site.
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Comma-separated SHA-256 hashes (hex) of the API keys allowed to call /api/v1.
# Generate one with:  npm run generate-key
#
# These are hashes, not secrets — the plaintext key is only ever held by the
# consumer. If this variable is empty, /api/v1 rejects every request with a 503
# rather than serving data unauthenticated.
WALLETNEST_API_KEYS=
